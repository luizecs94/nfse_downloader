# =============================================================
#  NFS-e Downloader — Configuração da Empresa
#  Renomeie este arquivo para .env e preencha os dados abaixo
# =============================================================

# Nome da empresa (exibido nos logs e relatórios)
EMPRESA_NOME=Razao Social da Empresa Ltda

# CNPJ da empresa — somente números, sem pontos ou traços
NFSE_USUARIO=00000000000000

# Certificado Digital A1 (ICP-Brasil) — OBRIGATÓRIO
# Coloque o arquivo .pfx dentro da pasta certificados/
CERTIFICADO_PATH=certificados/empresa.pfx
CERTIFICADO_SENHA=senha_do_certificado

# Pasta onde XMLs e PDFs serão salvos
DOWNLOAD_PATH=downloads

# Estrutura de subpastas — tags disponíveis:
# {ANO} {MES} {DIA} {CNPJ_TOMADOR} {CNPJ_PRESTADOR} {MUNICIPIO}
PATH_STRUCTURE={CNPJ_TOMADOR}/{ANO}/{MES}

# URL da API (não altere para produção)
ADN_BASE_URL=https://adn.nfse.gov.br
